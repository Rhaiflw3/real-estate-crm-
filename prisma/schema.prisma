// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Lead {
  id          String          @id @default(uuid())
  name        String
  email       String
  phone       String?
  status      String          @default("New")
  source      String          @default("Website")
  aiSummary   String?         @map("ai_summary")
  notes       String?
  userId      String?         @map("user_id")
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  propertyLinks LeadProperty[]
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("leads")
}

model Property {
  id            String             @id @default(uuid())
  title         String
  description   String?
  price         Decimal            @db.Decimal(12, 2)
  status        String             @default("Available")
  type          String             @default("House")
  bedrooms      Int?
  bathrooms     Int?
  areaSqFt      Int?               @map("area_sq_ft")
  address       String?
  city          String?
  state         String?
  zipCode       String?            @map("zip_code")
  notes         String?
  userId        String             @map("user_id")
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioLinks PortfolioProperty[]
  leadLinks     LeadProperty[]
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@map("properties")
}

model Portfolio {
  id          String             @id @default(uuid())
  name        String
  description String?
  year        Int?
  type        String             @default("Standard")
  status      String             @default("Active")
  userId      String             @map("user_id")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties  PortfolioProperty[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("portfolios")
}

model PortfolioProperty {
  id           String   @id @default(uuid())
  portfolioId  String   @map("portfolio_id")
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  propertyId   String   @map("property_id")
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([portfolioId, propertyId])
  @@map("portfolio_properties")
}

model LeadProperty {
  id            String   @id @default(uuid())
  leadId        String   @map("lead_id")
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId    String   @map("property_id")
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  interestLevel String   @default("Medium")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([leadId, propertyId])
  @@map("lead_properties")
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  name       String?
  leads      Lead[]
  properties Property[]
  portfolios Portfolio[]
  sessions   Session[]
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}